{
  "name": "@forgedesk/api",
  "version": "3.0.3",
  "description": "Typed JavaScript API bindings for Forge desktop applications",
  "license": "MIT",
  "homepage": "https://forgedesk.eu.cc",
  "repository": {
    "type": "git",
    "url": "https://github.com/swadhinbiswas/ForgeDesk.git",
    "directory": "packages/api"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./window": {
      "types": "./dist/window.d.ts",
      "default": "./dist/window.js"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "default": "./dist/fs.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "default": "./dist/dialog.js"
    },
    "./clipboard": {
      "types": "./dist/clipboard.d.ts",
      "default": "./dist/clipboard.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "default": "./dist/shell.js"
    },
    "./menu": {
      "types": "./dist/menu.d.ts",
      "default": "./dist/menu.js"
    },
    "./tray": {
      "types": "./dist/tray.d.ts",
      "default": "./dist/tray.js"
    },
    "./notifications": {
      "types": "./dist/notifications.d.ts",
      "default": "./dist/notifications.js"
    },
    "./updater": {
      "types": "./dist/updater.d.ts",
      "default": "./dist/updater.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "mkdir -p dist && cp index.js dist/index.js && cp index.d.ts dist/index.d.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "forge",
    "desktop",
    "ipc",
    "webview",
    "python",
    "tauri-alternative"
  ]
}
